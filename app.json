{
  "expo": {
    "name": "CVGratuit Builder",
    "slug": "cvgratuit-builder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F4EF"
    },
    "scheme": "cvgratuit",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cvgratuit.builder"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F4EF"
      },
      "package": "com.cvgratuit.builder",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Accès à vos photos pour ajouter une photo sur votre CV."
        }
      ],
      [
        "./plugins/withGoogleMobileAds",
        {
          "androidAppId": "ca-app-pub-9374827284535461~9818535525",
          "iosAppId": "ca-app-pub-9374827284535461~9818535525"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "24df4f16-488f-4ce9-8d7a-d1bff78666eb"
      }
    },
    "owner": "souf2001"
  }
}
